{
  "name": "stackdiff",
  "version": "0.1.0",
  "description": "CLI tool to compare dependency trees across branches and surface breaking version changes",
  "main": "dist/index.js",
  "bin": {
    "stackdiff": "dist/cli.js"
  },
  "scripts": {
